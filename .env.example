# ============================================
# AI Lesson Generator - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ============================================

# ============================================
# REQUIRED: Anthropic API Key
# ============================================
# Get your API key from: https://console.anthropic.com/
# Required for lesson generation functionality
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ============================================
# OPTIONAL: Lesson Archive System
# ============================================
# Set to 'true' to enable lesson archiving feature
# Default: false (archiving disabled)
ENABLE_ARCHIVE=false

# Admin password for moderation panel (if ENABLE_ARCHIVE=true)
# Use a strong password (12+ characters recommended)
ADMIN_PASSWORD=your_secure_password_here

# ============================================
# OPTIONAL: Partner Referral Links
# ============================================
# ElevenLabs referral link or code
# Format: Full URL (https://...) or referral code
# Leave empty to disable affiliate links
ELEVEN_LABS_PARTNER_REFERRAL_LINK=

# VideoGen referral code
# Format: Referral code only
# Leave empty to disable affiliate links
VIDEOGEN_PARTNER_REFFERAL_CODE=

# ============================================
# OPTIONAL: Development Settings
# ============================================
# Set to 'development' for detailed error messages
# Default: production
NODE_ENV=production
