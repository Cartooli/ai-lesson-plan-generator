# ============================================
# AI Lesson Plan Generator - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# REQUIRED - Anthropic API Key
# ============================================
# Get your API key from: https://console.anthropic.com/
# Required for lesson generation functionality
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ============================================
# OPTIONAL - Model Configuration
# ============================================
# Which Claude model to use for lesson generation
# Default: claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Override max output tokens for the model response
# Default: 4096
# ANTHROPIC_MAX_TOKENS=4096

# ============================================
# OPTIONAL - Archive System
# ============================================
# Enable lesson plan archiving and moderation
# Set to 'true' to enable, 'false' to disable (default: false)
ENABLE_ARCHIVE=false

# Admin password for archive moderation panel
# Required if ENABLE_ARCHIVE=true
# Use a strong password (12+ characters recommended)
ADMIN_PASSWORD=your_strong_password_here

# ============================================
# OPTIONAL - Environment Configuration
# ============================================
# Environment mode: 'development' or 'production'
# Default: 'production'
NODE_ENV=production

# ============================================
# OPTIONAL - Security & Rate Limiting
# ============================================
# Comma-separated list of allowed origins for CORS
# Leave empty or set to '*' for all origins (less secure)
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=*

# Rate limiting: Maximum requests per window
# Default: 10 requests per minute
RATE_LIMIT_MAX_REQUESTS=10

# Rate limiting: Time window in milliseconds
# Default: 60000 (1 minute)
RATE_LIMIT_WINDOW_MS=60000
