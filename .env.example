# AI Lesson Generator - Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ============================================
# REQUIRED VARIABLES
# ============================================

# Anthropic API Key (Required)
# Get your key from: https://console.anthropic.com/
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ============================================
# OPTIONAL VARIABLES
# ============================================

# Enable lesson archiving system (default: false)
# Set to 'true' to enable archiving and moderation features
# Requires ADMIN_PASSWORD if enabled
ENABLE_ARCHIVE=false

# Admin password for moderation panel (required if ENABLE_ARCHIVE=true)
# Use a strong password (12+ characters recommended)
ADMIN_PASSWORD=

# ElevenLabs partner referral link (optional)
# Leave empty to disable ElevenLabs referral links
ELEVEN_LABS_PARTNER_REFERRAL_LINK=

# VideoGen partner referral code (optional)
# Leave empty to disable VideoGen referral codes
VIDEOGEN_PARTNER_REFFERAL_CODE=

# Environment mode (default: production)
# Options: 'development' or 'production'
# Development mode shows detailed error messages
NODE_ENV=production
